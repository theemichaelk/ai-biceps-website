# Copy to .env and fill in values (never commit .env)

# Option A — paste your form endpoint from Formspree dashboard (Integration tab)
# TSBR_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Option B — use Formspree CLI deploy (Settings → Deploy key in Formspree dashboard)
# FORMSPREE_DEPLOY_KEY=your-deploy-key-here

# Optional
# TSBR_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# TSBR_GOOGLE_MAPS_EMBED=https://maps.google.com/maps?q=518+Brynmawr+Ct,+Arlington,+TX+76014&output=embed
# TSBR_GOOGLE_PROFILE=https://www.google.com/maps/search/?api=1&query=The+Stone+Builders+Rejected+Arlington+TX
# TSBR_LINKEDIN=https://www.linkedin.com/company/your-page
# TSBR_FACEBOOK=https://www.facebook.com/your-page
# TSBR_TWITTER=https://x.com/your-handle
# TSBR_INSTAGRAM=https://www.instagram.com/your-handle

# Deploy (scripts/deploy.ps1)
# TSBR_FTP_HOST=ftp.yourhost.com
# TSBR_FTP_USER=your-ftp-user
# TSBR_FTP_PASSWORD=your-ftp-password
# TSBR_FTP_REMOTE_PATH=/public_html
# TSBR_DEPLOY_LOCAL_PATH=C:\path\to\web\root